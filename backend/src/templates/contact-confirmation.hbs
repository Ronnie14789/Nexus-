<!doctype html>
<html lang="en">
  <body style="margin:0;background:#eef4fa;font-family:Arial,sans-serif;color:#0b1a2b;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="padding:32px 16px;background:#eef4fa;">
      <tr><td align="center">
        <table role="presentation" width="620" cellpadding="0" cellspacing="0" style="max-width:620px;background:#ffffff;border-radius:22px;overflow:hidden;box-shadow:0 18px 45px rgba(12,35,58,.12);">
          <tr>
            <td style="padding:30px 34px;background:linear-gradient(135deg,#061528,#0b2a4b);color:#ffffff;">
              <div style="font-size:12px;letter-spacing:2px;text-transform:uppercase;color:#71cfff;font-weight:700;">Ecatu Ronald</div>
              <h1 style="margin:12px 0 0;font-size:28px;line-height:1.2;">Your message was received.</h1>
            </td>
          </tr>
          <tr>
            <td style="padding:34px;">
              <p style="margin:0 0 18px;line-height:1.7;">Hello {{name}},</p>
              <p style="margin:0 0 24px;line-height:1.7;color:#41576b;">Thank you for contacting me through my professional portfolio. Your message has been saved securely and I will reply as soon as possible.</p>
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="border:1px solid #dbe6ef;border-radius:14px;background:#f7fafc;">
                <tr><td style="padding:18px 20px;border-bottom:1px solid #dbe6ef;"><strong style="font-size:12px;color:#0b6cff;text-transform:uppercase;letter-spacing:1px;">Enquiry type</strong><div style="margin-top:6px;">{{enquiryType}}</div></td></tr>
                <tr><td style="padding:18px 20px;border-bottom:1px solid #dbe6ef;"><strong style="font-size:12px;color:#0b6cff;text-transform:uppercase;letter-spacing:1px;">Subject</strong><div style="margin-top:6px;">{{subject}}</div></td></tr>
                <tr><td style="padding:18px 20px;"><strong style="font-size:12px;color:#0b6cff;text-transform:uppercase;letter-spacing:1px;">Message</strong><div style="margin-top:8px;white-space:pre-line;line-height:1.65;color:#41576b;">{{message}}</div></td></tr>
              </table>
              <p style="margin:26px 0 0;line-height:1.7;color:#41576b;">Regards,<br><strong>Ecatu Ronald</strong><br>Electrical &amp; Automotive Systems Engineer</p>
            </td>
          </tr>
          <tr><td style="padding:18px 34px;background:#f4f7fb;color:#73879a;font-size:12px;">This confirmation was sent automatically from the portfolio server. © {{year}} Ecatu Ronald.</td></tr>
        </table>
      </td></tr>
    </table>
  </body>
</html>
