<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="x-apple-disable-message-reformatting">
    <meta name="format-detection" content="telephone=no,address=no,email=no,date=no,url=no">
    <meta name="color-scheme" content="light">
    <meta name="supported-color-schemes" content="light">
    <title>New professional enquiry · {{referenceNumber}}</title>
    <style>
      @media screen and (max-width:560px) {
        .email-pad { padding-left:20px !important; padding-right:20px !important; }
        .header-status { display:none !important; }
        .stack-cell { display:block !important; width:auto !important; border-right:0 !important; }
        .action-cell { display:block !important; width:100% !important; }
        .action-cell a { display:block !important; text-align:center !important; }
        .action-gap { display:block !important; width:100% !important; height:10px !important; }
        .footer-cell { display:block !important; width:auto !important; text-align:left !important; padding-top:8px !important; }
      }
    </style>
  </head>
  <body style="margin:0;padding:0;background-color:#eef2f6;color:#172234;font-family:Arial,'Helvetica Neue',Helvetica,sans-serif;-webkit-text-size-adjust:100%;">
    <div style="display:none;max-height:0;overflow:hidden;opacity:0;color:transparent;mso-hide:all;">
      {{name}} sent a {{enquiryType}} enquiry · {{referenceNumber}}.
    </div>

    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="width:100%;background-color:#eef2f6;">
      <tr>
        <td align="center" style="padding:32px 12px;">
          <table role="presentation" width="640" cellpadding="0" cellspacing="0" border="0" style="width:100%;max-width:640px;background-color:#ffffff;border:1px solid #dce3ea;border-radius:16px;overflow:hidden;">
            <tr>
              <td style="height:5px;background-color:#246bfd;font-size:0;line-height:0;">&nbsp;</td>
            </tr>
            <tr>
              <td class="email-pad" style="padding:24px 28px;border-bottom:1px solid #e5eaf0;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                  <tr>
                    <td width="48" valign="middle">
                      <div style="width:40px;height:40px;line-height:40px;text-align:center;border-radius:50%;background-color:#10223e;color:#76edff;font-size:18px;font-weight:700;letter-spacing:.5px;border:1px solid #315476;">N</div>
                    </td>
                    <td valign="middle">
                      <div style="font-size:15px;line-height:1.3;color:#10223e;font-weight:700;letter-spacing:1.4px;">NEXUS</div>
                      <div style="margin-top:3px;font-size:11px;line-height:1.4;color:#637083;letter-spacing:.6px;text-transform:uppercase;">by Ecatu Ronald · Professional correspondence</div>
                    </td>
                    <td class="header-status" align="right" valign="middle">
                      <span style="display:inline-block;padding:6px 9px;border-radius:999px;background-color:#edf3ff;color:#1f5bc4;font-size:10px;line-height:1.2;font-weight:700;letter-spacing:.8px;text-transform:uppercase;">New enquiry</span>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <tr>
              <td class="email-pad" style="padding:32px 28px 12px;">
                <div style="font-size:11px;line-height:1.4;color:#246bfd;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;">Portfolio contact</div>
                <h1 style="margin:8px 0 10px;font-size:28px;line-height:1.2;color:#10223e;font-weight:700;letter-spacing:-.4px;">New professional enquiry</h1>
                <p style="margin:0;font-size:15px;line-height:1.7;color:#58677a;">A new message was submitted through ecaturonald.tech. Review the sender, subject and message before responding.</p>
              </td>
            </tr>

            <tr>
              <td class="email-pad" style="padding:18px 28px 0;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#f6f8fb;border:1px solid #dfe5ec;border-radius:12px;">
                  <tr>
                    <td class="stack-cell" width="58%" valign="top" style="padding:18px 20px;border-right:1px solid #dfe5ec;">
                      <div style="font-size:10px;line-height:1.3;color:#6c7989;font-weight:700;letter-spacing:1px;text-transform:uppercase;">Reference number</div>
                      <div style="margin-top:7px;font-size:18px;line-height:1.3;color:#10223e;font-weight:700;letter-spacing:.4px;">{{referenceNumber}}</div>
                    </td>
                    <td class="stack-cell" width="42%" valign="top" style="padding:18px 20px;">
                      <div style="font-size:10px;line-height:1.3;color:#6c7989;font-weight:700;letter-spacing:1px;text-transform:uppercase;">Category</div>
                      <div style="margin-top:7px;font-size:13px;line-height:1.5;color:#24364d;font-weight:700;">{{enquiryType}}</div>
                    </td>
                  </tr>
                  <tr>
                    <td colspan="2" style="padding:13px 20px;border-top:1px solid #dfe5ec;font-size:12px;line-height:1.5;color:#68778a;">Received {{submittedAt}} · East Africa Time</td>
                  </tr>
                </table>
              </td>
            </tr>

            <tr>
              <td class="email-pad" style="padding:26px 28px 0;">
                <div style="margin-bottom:10px;font-size:10px;line-height:1.3;color:#6c7989;font-weight:700;letter-spacing:1px;text-transform:uppercase;">Sender details</div>
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="border:1px solid #dfe5ec;border-radius:12px;overflow:hidden;">
                  <tr>
                    <td class="stack-cell" width="50%" valign="top" style="padding:16px 18px;border-right:1px solid #e4e9ef;border-bottom:1px solid #e4e9ef;">
                      <div style="font-size:10px;line-height:1.3;color:#7a8797;font-weight:700;text-transform:uppercase;letter-spacing:.8px;">Name</div>
                      <div style="margin-top:6px;font-size:14px;line-height:1.5;color:#172234;font-weight:700;">{{name}}</div>
                    </td>
                    <td class="stack-cell" width="50%" valign="top" style="padding:16px 18px;border-bottom:1px solid #e4e9ef;">
                      <div style="font-size:10px;line-height:1.3;color:#7a8797;font-weight:700;text-transform:uppercase;letter-spacing:.8px;">Phone</div>
                      <div style="margin-top:6px;font-size:14px;line-height:1.5;color:#172234;">{{phone}}</div>
                    </td>
                  </tr>
                  <tr>
                    <td colspan="2" style="padding:16px 18px;">
                      <div style="font-size:10px;line-height:1.3;color:#7a8797;font-weight:700;text-transform:uppercase;letter-spacing:.8px;">Email</div>
                      <div style="margin-top:6px;font-size:14px;line-height:1.5;"><a href="mailto:{{email}}" style="color:#185bc8;text-decoration:underline;font-weight:700;">{{email}}</a></div>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <tr>
              <td class="email-pad" style="padding:26px 28px 0;">
                <div style="margin-bottom:8px;font-size:10px;line-height:1.3;color:#6c7989;font-weight:700;letter-spacing:1px;text-transform:uppercase;">Subject</div>
                <div style="font-size:20px;line-height:1.4;color:#172234;font-weight:700;">{{subject}}</div>
              </td>
            </tr>

            <tr>
              <td class="email-pad" style="padding:22px 28px 0;">
                <div style="margin-bottom:9px;font-size:10px;line-height:1.3;color:#6c7989;font-weight:700;letter-spacing:1px;text-transform:uppercase;">Message</div>
                <div style="padding:18px 20px;background-color:#f7f9fb;border:1px solid #e1e7ed;border-left:4px solid #246bfd;border-radius:8px;font-size:14px;line-height:1.75;color:#34465c;white-space:pre-line;">{{message}}</div>
              </td>
            </tr>

            <tr>
              <td class="email-pad" style="padding:26px 28px 10px;">
                <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                  <tr>
                    <td class="action-cell" style="border-radius:8px;background-color:#246bfd;">
                      <a href="{{replyUrl}}" style="display:inline-block;padding:13px 18px;color:#ffffff;text-decoration:none;font-size:13px;line-height:1.2;font-weight:700;">Reply to {{name}}</a>
                    </td>
                    <td class="action-gap" width="10"></td>
                    <td class="action-cell" style="border:1px solid #ccd5df;border-radius:8px;background-color:#ffffff;">
                      <a href="{{adminUrl}}" style="display:inline-block;padding:12px 18px;color:#24364d;text-decoration:none;font-size:13px;line-height:1.2;font-weight:700;">View contact record</a>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <tr>
              <td class="email-pad" style="padding:18px 28px 32px;">
                <div style="padding:14px 16px;background-color:#fff8e8;border:1px solid #f1dfaa;border-radius:8px;font-size:12px;line-height:1.65;color:#66552c;">
                  <strong style="color:#4f421f;">Response check:</strong> Confirm the request and sender details before sharing confidential, commercial or account information.
                </div>
              </td>
            </tr>

            <tr>
              <td class="email-pad" style="padding:20px 28px;background-color:#10223e;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                  <tr>
                    <td valign="top" style="font-size:11px;line-height:1.65;color:#b9c4d2;">
                      <strong style="color:#ffffff;">Nexus · Professional Correspondence</strong><br>
                      Automated administrative notice from <a href="{{siteUrl}}" style="color:#9ec1ff;text-decoration:none;">ecaturonald.tech</a>
                    </td>
                    <td class="footer-cell" align="right" valign="top" style="font-size:10px;line-height:1.65;color:#8f9daf;">
                      Submission {{submissionId}}<br>© {{year}} Ecatu Ronald
                    </td>
                  </tr>
                </table>
              </td>
            </tr>
          </table>

          <div style="max-width:640px;margin:14px auto 0;font-size:10px;line-height:1.6;color:#8490a0;text-align:center;">
            This private notification was generated because the portfolio contact form received a submission.
          </div>
        </td>
      </tr>
    </table>
  </body>
</html>
