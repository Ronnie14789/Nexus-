<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="x-apple-disable-message-reformatting">
    <meta name="format-detection" content="telephone=no,address=no,email=no,date=no,url=no">
    <meta name="color-scheme" content="light">
    <title>{{postTitle}} · Ecatu Ronald</title>
    <style>@media screen and (max-width:560px){.email-pad{padding-left:20px !important;padding-right:20px !important}.header-meta{display:none !important}}</style>
  </head>
  <body style="margin:0;padding:0;background-color:#eef2f6;color:#172234;font-family:Arial,'Helvetica Neue',Helvetica,sans-serif;-webkit-text-size-adjust:100%;">
    <div style="display:none;max-height:0;overflow:hidden;opacity:0;color:transparent;mso-hide:all;">New from Ecatu Ronald: {{postTitle}}</div>
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="width:100%;background-color:#eef2f6;">
      <tr>
        <td align="center" style="padding:32px 12px;">
          <table role="presentation" width="640" cellpadding="0" cellspacing="0" border="0" style="width:100%;max-width:640px;background-color:#ffffff;border:1px solid #dce3ea;border-radius:16px;overflow:hidden;">
            <tr><td style="height:5px;background-color:#246bfd;font-size:0;line-height:0;">&nbsp;</td></tr>
            <tr>
              <td class="email-pad" style="padding:24px 28px;border-bottom:1px solid #e5eaf0;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"><tr>
                  <td width="48"><div style="width:40px;height:40px;line-height:40px;text-align:center;border-radius:10px;background-color:#10223e;color:#ffffff;font-size:15px;font-weight:700;">ER</div></td>
                  <td><div style="font-size:15px;line-height:1.3;color:#10223e;font-weight:700;">Ecatu Ronald</div><div style="margin-top:3px;font-size:11px;color:#637083;letter-spacing:.6px;text-transform:uppercase;">Engineering field notes</div></td>
                  <td class="header-meta" align="right" style="font-size:10px;color:#667588;font-weight:700;letter-spacing:.8px;text-transform:uppercase;">New publication</td>
                </tr></table>
              </td>
            </tr>
            {{#if featuredImage}}
            <tr><td><img src="{{featuredImage}}" width="640" alt="" style="display:block;width:100%;max-width:640px;height:auto;border:0;"></td></tr>
            {{/if}}
            <tr>
              <td class="email-pad" style="padding:38px 28px 14px;">
                <div style="font-size:11px;color:#246bfd;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;">New technical publication</div>
                <h1 style="margin:10px 0 14px;font-size:30px;line-height:1.2;color:#10223e;font-weight:700;letter-spacing:-.5px;">{{postTitle}}</h1>
                <p style="margin:0;font-size:15px;line-height:1.8;color:#58677a;">{{postExcerpt}}</p>
              </td>
            </tr>
            <tr>
              <td class="email-pad" style="padding:22px 28px 34px;">
                <table role="presentation" cellpadding="0" cellspacing="0" border="0"><tr><td style="border-radius:8px;background-color:#246bfd;"><a href="{{postUrl}}" style="display:inline-block;padding:13px 19px;color:#ffffff;text-decoration:none;font-size:13px;font-weight:700;">Read the publication</a></td></tr></table>
                <p style="margin:22px 0 0;font-size:12px;line-height:1.65;color:#7a8797;">Hello {{name}}—this update was sent because you subscribed to engineering field notes from ecaturonald.tech.</p>
              </td>
            </tr>
            <tr>
              <td class="email-pad" style="padding:19px 28px;background-color:#f6f8fb;border-top:1px solid #e1e7ed;font-size:11px;line-height:1.65;color:#778596;">Prefer not to receive publication updates? <a href="{{unsubscribeUrl}}" style="color:#315f9d;text-decoration:underline;">Unsubscribe here</a>. © {{year}} Ecatu Ronald.</td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
