<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="x-apple-disable-message-reformatting">
    <meta name="format-detection" content="telephone=no,address=no,email=no,date=no,url=no">
    <meta name="color-scheme" content="light">
    <meta name="supported-color-schemes" content="light">
    <title>Message received · {{referenceNumber}}</title>
    <style>
      @media screen and (max-width:560px) {
        .email-pad { padding-left:20px !important; padding-right:20px !important; }
        .header-status { display:none !important; }
      }
    </style>
  </head>
  <body style="margin:0;padding:0;background-color:#eef2f6;color:#172234;font-family:Arial,'Helvetica Neue',Helvetica,sans-serif;-webkit-text-size-adjust:100%;">
    <div style="display:none;max-height:0;overflow:hidden;opacity:0;color:transparent;mso-hide:all;">
      Thank you, {{name}}. Your message was received with reference {{referenceNumber}}.
    </div>

    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="width:100%;background-color:#eef2f6;">
      <tr>
        <td align="center" style="padding:32px 12px;">
          <table role="presentation" width="640" cellpadding="0" cellspacing="0" border="0" style="width:100%;max-width:640px;background-color:#ffffff;border:1px solid #dce3ea;border-radius:16px;overflow:hidden;">
            <tr>
              <td style="height:5px;background-color:#246bfd;font-size:0;line-height:0;">&nbsp;</td>
            </tr>
            <tr>
              <td class="email-pad" style="padding:24px 28px;border-bottom:1px solid #e5eaf0;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                  <tr>
                    <td width="48" valign="middle">
                      <div style="width:40px;height:40px;line-height:40px;text-align:center;border-radius:10px;background-color:#10223e;color:#ffffff;font-size:15px;font-weight:700;letter-spacing:.5px;">ER</div>
                    </td>
                    <td valign="middle">
                      <div style="font-size:15px;line-height:1.3;color:#10223e;font-weight:700;">Ecatu Ronald</div>
                      <div style="margin-top:3px;font-size:11px;line-height:1.4;color:#637083;letter-spacing:.6px;text-transform:uppercase;">Systems engineering portfolio</div>
                    </td>
                    <td class="header-status" align="right" valign="middle">
                      <span style="display:inline-block;padding:6px 9px;border-radius:999px;background-color:#edf7f2;color:#267255;font-size:10px;line-height:1.2;font-weight:700;letter-spacing:.8px;text-transform:uppercase;">Received</span>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <tr>
              <td class="email-pad" style="padding:38px 28px 12px;">
                <div style="font-size:11px;line-height:1.4;color:#246bfd;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;">Message confirmation</div>
                <h1 style="margin:9px 0 12px;font-size:30px;line-height:1.18;color:#10223e;font-weight:700;letter-spacing:-.5px;">Thank you, {{name}}.</h1>
                <p style="margin:0;font-size:16px;line-height:1.75;color:#58677a;">Your enquiry has been received and recorded for review. This confirmation includes the details submitted through ecaturonald.tech.</p>
              </td>
            </tr>

            <tr>
              <td class="email-pad" style="padding:22px 28px 0;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#f6f8fb;border:1px solid #dfe5ec;border-radius:12px;">
                  <tr>
                    <td style="padding:19px 20px;">
                      <div style="font-size:10px;line-height:1.3;color:#6c7989;font-weight:700;letter-spacing:1px;text-transform:uppercase;">Reference number</div>
                      <div style="margin-top:7px;font-size:20px;line-height:1.3;color:#10223e;font-weight:700;letter-spacing:.4px;">{{referenceNumber}}</div>
                      <div style="margin-top:7px;font-size:12px;line-height:1.5;color:#68778a;">Submitted {{submittedAt}} · East Africa Time</div>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <tr>
              <td class="email-pad" style="padding:26px 28px 0;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="border:1px solid #dfe5ec;border-radius:12px;overflow:hidden;">
                  <tr>
                    <td style="padding:15px 18px;border-bottom:1px solid #e4e9ef;">
                      <div style="font-size:10px;line-height:1.3;color:#7a8797;font-weight:700;text-transform:uppercase;letter-spacing:.8px;">Enquiry category</div>
                      <div style="margin-top:6px;font-size:14px;line-height:1.5;color:#172234;">{{enquiryType}}</div>
                    </td>
                  </tr>
                  <tr>
                    <td style="padding:15px 18px;">
                      <div style="font-size:10px;line-height:1.3;color:#7a8797;font-weight:700;text-transform:uppercase;letter-spacing:.8px;">Subject</div>
                      <div style="margin-top:6px;font-size:14px;line-height:1.5;color:#172234;font-weight:700;">{{subject}}</div>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <tr>
              <td class="email-pad" style="padding:24px 28px 0;">
                <div style="margin-bottom:9px;font-size:10px;line-height:1.3;color:#6c7989;font-weight:700;letter-spacing:1px;text-transform:uppercase;">Your message</div>
                <div style="padding:18px 20px;background-color:#f7f9fb;border:1px solid #e1e7ed;border-left:4px solid #246bfd;border-radius:8px;font-size:14px;line-height:1.75;color:#34465c;white-space:pre-line;">{{message}}</div>
              </td>
            </tr>

            <tr>
              <td class="email-pad" style="padding:26px 28px 0;">
                <div style="padding:20px;background-color:#10223e;border-radius:10px;">
                  <div style="font-size:11px;line-height:1.3;color:#9ec1ff;font-weight:700;letter-spacing:1px;text-transform:uppercase;">What happens next</div>
                  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top:13px;">
                    <tr>
                      <td width="28" valign="top" style="font-size:12px;line-height:22px;color:#ffffff;font-weight:700;">01</td>
                      <td style="padding-bottom:10px;font-size:13px;line-height:1.65;color:#d0d8e3;">The enquiry and relevant technical context will be reviewed.</td>
                    </tr>
                    <tr>
                      <td width="28" valign="top" style="font-size:12px;line-height:22px;color:#ffffff;font-weight:700;">02</td>
                      <td style="padding-bottom:10px;font-size:13px;line-height:1.65;color:#d0d8e3;">A response will be sent to the email address you provided.</td>
                    </tr>
                    <tr>
                      <td width="28" valign="top" style="font-size:12px;line-height:22px;color:#ffffff;font-weight:700;">03</td>
                      <td style="font-size:13px;line-height:1.65;color:#d0d8e3;">Use reference <strong style="color:#ffffff;">{{referenceNumber}}</strong> if you follow up.</td>
                    </tr>
                  </table>
                </div>
              </td>
            </tr>

            <tr>
              <td class="email-pad" style="padding:26px 28px 10px;">
                <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                  <tr>
                    <td style="border-radius:8px;background-color:#246bfd;">
                      <a href="{{siteUrl}}" style="display:inline-block;padding:13px 19px;color:#ffffff;text-decoration:none;font-size:13px;line-height:1.2;font-weight:700;">Visit ecaturonald.tech</a>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <tr>
              <td class="email-pad" style="padding:22px 28px 32px;">
                <div style="padding-top:21px;border-top:1px solid #e1e7ed;font-size:13px;line-height:1.7;color:#667588;">
                  Regards,<br>
                  <strong style="color:#172234;">Ecatu Ronald</strong><br>
                  Electrical, automotive and digital systems<br>
                  Kampala, Uganda
                </div>
              </td>
            </tr>

            <tr>
              <td class="email-pad" style="padding:19px 28px;background-color:#f6f8fb;border-top:1px solid #e1e7ed;font-size:11px;line-height:1.65;color:#778596;">
                This automated confirmation relates only to the enquiry referenced above. Contact details are used to review and respond to the submission. © {{year}} Ecatu Ronald.
              </td>
            </tr>
          </table>

          <div style="max-width:640px;margin:14px auto 0;font-size:10px;line-height:1.6;color:#8490a0;text-align:center;">
            Sent by ecaturonald.tech · Please keep this confirmation for your records.
          </div>
        </td>
      </tr>
    </table>
  </body>
</html>
