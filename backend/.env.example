# =========================================================
# ECATU RONALD PORTFOLIO SERVER
# Copy this file to backend/.env for local development.
# Never commit the real .env file.
# =========================================================

# Application
NODE_ENV=development
PORT=3001
LOG_LEVEL=info
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001
STATIC_FRONTEND_DIR=

# Contact storage
# MongoDB is recommended for production. When unavailable and
# DATABASE_REQUIRED=false, messages are stored in CONTACT_FALLBACK_FILE.
# If backend/.env is missing or MONGODB_URI is unset, startup logs explain the fallback.
#
# MongoDB Atlas (cloud) — replace USERNAME, PASSWORD, CLUSTER, and AppName with your values.
# The database name (ecatu_portfolio below) MUST be included — add it after the hostname.
# If your password contains @ : / ? # or % — URL-encode those characters first.
# Atlas URI format:
#   MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/ecatu_portfolio?retryWrites=true&w=majority&appName=AppName
# Specific cluster example for this project (replace YOUR_PASSWORD):
#   MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@ecatu.mmgbkst.mongodb.net/ecatu_portfolio?retryWrites=true&w=majority&appName=Ecatu
#
# Local MongoDB:
# MONGODB_URI=mongodb://localhost:27017/ecatu_portfolio
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/ecatu_portfolio?retryWrites=true&w=majority&appName=AppName
DATABASE_REQUIRED=false
CONTACT_FALLBACK_FILE=./data/contact-submissions.json
IP_HASH_SALT=replace-with-a-long-random-secret

# Optional Redis cache
REDIS_URL=

# Admin authentication
JWT_SECRET=replace-with-a-random-secret-at-least-32-characters
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
ADMIN_USERNAME=ecatu-admin
ADMIN_EMAIL=ronaldecatu@gmail.com
ADMIN_PASSWORD=replace-with-a-strong-password-at-least-12-characters

# SMTP email delivery
# The server stores contact messages even when SMTP is not configured.
# Gmail requires an App Password. Brevo/Resend SMTP credentials also work.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM_NAME=Ecatu Ronald Portfolio

# Optional Cloudinary image uploads for the private admin area
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional monitoring
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
ENABLE_PERFORMANCE_MONITORING=true
PERFORMANCE_SAMPLE_RATE=0.1
