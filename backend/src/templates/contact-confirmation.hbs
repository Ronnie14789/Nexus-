<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="x-apple-disable-message-reformatting">
    <title>Message received · {{referenceNumber}}</title>
  </head>
  <body style="margin:0;padding:0;background:#e8eef5;font-family:Arial,Helvetica,sans-serif;color:#102033;">
    <div style="display:none;max-height:0;overflow:hidden;opacity:0;color:transparent;">
      Your message has been received securely. Reference {{referenceNumber}}.
    </div>

    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="width:100%;background:#e8eef5;">
      <tr>
        <td align="center" style="padding:28px 12px;">
          <table role="presentation" width="640" cellpadding="0" cellspacing="0" border="0" style="width:100%;max-width:640px;background:#ffffff;border-radius:24px;overflow:hidden;box-shadow:0 20px 60px rgba(7,24,43,.14);">
            <tr>
              <td style="padding:0;background:#061525;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                  <tr>
                    <td style="padding:28px 32px;border-bottom:1px solid rgba(255,255,255,.10);">
                      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                        <tr>
                          <td width="54" valign="middle">
                            <div style="width:46px;height:46px;line-height:46px;text-align:center;border-radius:14px;background:#149cff;color:#ffffff;font-size:18px;font-weight:800;letter-spacing:1px;">ER</div>
                          </td>
                          <td valign="middle">
                            <div style="font-size:11px;line-height:1.4;letter-spacing:2.2px;text-transform:uppercase;color:#67c7ff;font-weight:700;">Nexus Field Systems</div>
                            <div style="margin-top:4px;font-size:18px;line-height:1.3;color:#ffffff;font-weight:700;">Ecatu Ronald</div>
                          </td>
                          <td align="right" valign="middle" style="font-size:11px;color:#8da7bd;letter-spacing:1px;">SECURE MESSAGE CHANNEL</td>
                        </tr>
                      </table>
                    </td>
                  </tr>
                  <tr>
                    <td style="padding:42px 32px 38px;background:#061525;">
                      <div style="display:inline-block;padding:7px 11px;border:1px solid rgba(103,199,255,.35);border-radius:999px;color:#67c7ff;font-size:10px;line-height:1;letter-spacing:1.7px;font-weight:700;text-transform:uppercase;">Transmission received</div>
                      <h1 style="margin:18px 0 12px;font-size:34px;line-height:1.15;color:#ffffff;font-weight:800;letter-spacing:-.8px;">Your message is safely in the system.</h1>
                      <p style="margin:0;max-width:520px;font-size:16px;line-height:1.75;color:#b7c8d7;">Thank you, {{name}}. Your enquiry has been recorded and assigned a permanent reference number for follow-up.</p>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <tr>
              <td style="padding:32px;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#f4f8fc;border:1px solid #dbe6ef;border-radius:18px;">
                  <tr>
                    <td style="padding:22px 24px;">
                      <div style="font-size:10px;letter-spacing:1.8px;text-transform:uppercase;color:#60778d;font-weight:700;">Message reference</div>
                      <div style="margin-top:7px;font-size:24px;line-height:1.2;color:#071a2e;font-weight:800;letter-spacing:1px;">{{referenceNumber}}</div>
                      <div style="margin-top:8px;font-size:12px;line-height:1.5;color:#75899b;">Submitted {{submittedAt}} · East Africa Time</div>
                    </td>
                  </tr>
                </table>

                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top:24px;border-collapse:separate;border-spacing:0;">
                  <tr>
                    <td style="padding:0 0 8px;font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:#6a8195;font-weight:700;">Enquiry type</td>
                  </tr>
                  <tr>
                    <td style="padding:14px 16px;background:#ffffff;border:1px solid #dce6ef;border-radius:12px;font-size:14px;line-height:1.5;color:#102033;">{{enquiryType}}</td>
                  </tr>
                  <tr><td height="14"></td></tr>
                  <tr>
                    <td style="padding:0 0 8px;font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:#6a8195;font-weight:700;">Subject</td>
                  </tr>
                  <tr>
                    <td style="padding:14px 16px;background:#ffffff;border:1px solid #dce6ef;border-radius:12px;font-size:14px;line-height:1.5;color:#102033;font-weight:700;">{{subject}}</td>
                  </tr>
                  <tr><td height="14"></td></tr>
                  <tr>
                    <td style="padding:0 0 8px;font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:#6a8195;font-weight:700;">Your message</td>
                  </tr>
                  <tr>
                    <td style="padding:18px 18px;background:#f8fafc;border-left:4px solid #149cff;border-radius:0 12px 12px 0;font-size:14px;line-height:1.75;color:#40566a;white-space:pre-line;">{{message}}</td>
                  </tr>
                </table>

                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top:26px;background:#071a2e;border-radius:16px;">
                  <tr>
                    <td width="44" valign="top" style="padding:20px 0 20px 20px;">
                      <div style="width:30px;height:30px;line-height:30px;text-align:center;border-radius:50%;background:#12324e;color:#67c7ff;font-size:16px;">✓</div>
                    </td>
                    <td style="padding:20px 20px 20px 12px;">
                      <div style="font-size:13px;line-height:1.45;color:#ffffff;font-weight:700;">What happens next</div>
                      <div style="margin-top:5px;font-size:13px;line-height:1.7;color:#a9bdcd;">I will review the technical details and reply through the email address you supplied. Keep {{referenceNumber}} when following up.</div>
                    </td>
                  </tr>
                </table>

                <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin-top:28px;">
                  <tr>
                    <td style="border-radius:12px;background:#149cff;">
                      <a href="{{siteUrl}}" style="display:inline-block;padding:14px 22px;color:#ffffff;text-decoration:none;font-size:13px;font-weight:700;letter-spacing:.2px;">Return to ecaturonald.tech</a>
                    </td>
                  </tr>
                </table>

                <div style="margin-top:32px;padding-top:24px;border-top:1px solid #e0e8ef;font-size:13px;line-height:1.75;color:#60778d;">
                  Regards,<br>
                  <strong style="color:#102033;">Ecatu Ronald</strong><br>
                  Electrical &amp; Automotive Systems Engineer<br>
                  Kampala, Uganda
                </div>
              </td>
            </tr>

            <tr>
              <td style="padding:20px 32px;background:#f5f8fb;border-top:1px solid #e1e9f0;font-size:11px;line-height:1.65;color:#7a8ea1;">
                This automated confirmation was generated by the private Nexus communications infrastructure at ecaturonald.tech. Your details are used only to respond to your enquiry. © {{year}} Ecatu Ronald.
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
